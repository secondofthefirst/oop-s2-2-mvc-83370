@model Library.Domain.Premises

@{
    ViewData["Title"] = "Create Premises";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1>Add New Premises</h1>
            <hr />
            
            <form asp-action="Create" method="post" class="needs-validation">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Premises Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., McDonald's Bristol" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" placeholder="Street address" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Town" class="form-label">Town/City</label>
                    <input asp-for="Town" class="form-control" placeholder="e.g., Bristol" />
                    <span asp-validation-for="Town" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RiskRating" class="form-label">Risk Rating</label>
                    <select asp-for="RiskRating" class="form-select">
                        <option value="Low">Low</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>

                <div class="d-grid gap-2 d-sm-flex">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
