@model Library.Domain.Premises

@{
    ViewData["Title"] = "Delete Premises";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h3 class="text-danger">Delete Premises</h3>
            <hr />
            
            <div class="alert alert-warning">
                Are you sure you want to delete this premises? This action cannot be undone.
            </div>

            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@Model.Address</dd>

                <dt class="col-sm-3">Town</dt>
                <dd class="col-sm-9">@Model.Town</dd>

                <dt class="col-sm-3">Risk Rating</dt>
                <dd class="col-sm-9">@Model.RiskRating</dd>

                <dt class="col-sm-3">Inspections</dt>
                <dd class="col-sm-9">@Model.Inspections.Count</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
