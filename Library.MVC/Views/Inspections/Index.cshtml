@model IEnumerable<Library.Domain.Inspection>

@{
    ViewData["Title"] = "Inspections";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Inspections</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
            {
                <a asp-action="Create" class="btn btn-success">+ New Inspection</a>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Premises</th>
                    <th>Date</th>
                    <th>Score</th>
                    <th>Outcome</th>
                    <th>Follow-ups</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderByDescending(i => i.InspectionDate))
                {
                    <tr>
                        <td>
                            <strong>@item.Premises?.Name</strong>
                            <br />
                            <small class="text-muted">@item.Premises?.Town</small>
                        </td>
                        <td>@item.InspectionDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.Score <small>/100</small></td>
                        <td>
                            @if (item.Outcome == "Pass")
                            {
                                <span class="badge bg-success">Pass</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Fail</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-info">@item.FollowUps.Count</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">View</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No inspections recorded. <a asp-action="Create">Create a new inspection</a>
        </div>
    }
</div>
