@model Library.Domain.FollowUp

@{
    ViewData["Title"] = "Create Follow-up";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1>New Follow-up</h1>
            <hr />
            
            <form asp-action="Create" method="post" class="needs-validation">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="InspectionId" class="form-label">Inspection</label>
                    <select asp-for="InspectionId" class="form-select" asp-items="@(new SelectList(ViewBag.Inspections, "Id", "Id"))">
                        <option value="">-- Select Inspection --</option>
                    </select>
                    <small class="text-muted">Select the inspection this follow-up relates to</small>
                    <span asp-validation-for="InspectionId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DueDate" class="form-label">Due Date</label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                    <small class="text-muted">Must be on or after the inspection date</small>
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Open" selected>Open</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>

                <div class="mb-3" id="closedDateDiv" style="display:none;">
                    <label asp-for="ClosedDate" class="form-label">Closed Date</label>
                    <input asp-for="ClosedDate" type="date" class="form-control" />
                    <small class="text-muted">Required if status is Closed</small>
                    <span asp-validation-for="ClosedDate" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2 d-sm-flex">
                    <button type="submit" class="btn btn-primary">Create Follow-up</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const statusSelect = document.getElementById('Status');
        const closedDateDiv = document.getElementById('closedDateDiv');
        
        function updateClosedDateVisibility() {
            closedDateDiv.style.display = statusSelect.value === 'Closed' ? 'block' : 'none';
        }
        
        statusSelect.addEventListener('change', updateClosedDateVisibility);
        updateClosedDateVisibility();
    });
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
