@model IEnumerable<Library.Domain.FollowUp>

@{
    ViewData["Title"] = "Follow-ups";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Follow-ups</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
            {
                <a asp-action="Create" class="btn btn-success">+ New Follow-up</a>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Inspection</th>
                    <th>Premises</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Closed Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderBy(f => f.DueDate))
                {
                    var isOverdue = item.Status == "Open" && item.DueDate < DateTime.Now.Date;
                    <tr class="@(isOverdue ? "table-danger" : "")">
                        <td>
                            <a asp-controller="Inspections" asp-action="Details" asp-route-id="@item.InspectionId">
                                Inspection #@item.InspectionId
                            </a>
                        </td>
                        <td>
                            <strong>@item.Inspection?.Premises?.Name</strong>
                            <br />
                            <small class="text-muted">@item.Inspection?.Premises?.Town</small>
                        </td>
                        <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (isOverdue)
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else if (item.Status == "Open")
                            {
                                <span class="badge bg-warning text-dark">Open</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Closed</span>
                            }
                        </td>
                        <td>@item.ClosedDate?.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">View</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No follow-ups recorded. <a asp-action="Create">Create a new follow-up</a>
        </div>
    }
</div>
