@model Library.Domain.FollowUp

@{
    ViewData["Title"] = "Delete Follow-up";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h3 class="text-danger">Delete Follow-up</h3>
            <hr />
            
            <div class="alert alert-warning">
                Are you sure you want to delete this follow-up? This action cannot be undone.
            </div>

            <dl class="row">
                <dt class="col-sm-3">Inspection</dt>
                <dd class="col-sm-9">
                    <a asp-controller="Inspections" asp-action="Details" asp-route-id="@Model.InspectionId">
                        Inspection #@Model.InspectionId
                    </a>
                </dd>

                <dt class="col-sm-3">Premises</dt>
                <dd class="col-sm-9">@Model.Inspection?.Premises?.Name (@Model.Inspection?.Premises?.Town)</dd>

                <dt class="col-sm-3">Due Date</dt>
                <dd class="col-sm-9">@Model.DueDate.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                @if (Model.ClosedDate.HasValue)
                {
                    <dt class="col-sm-3">Closed Date</dt>
                    <dd class="col-sm-9">@Model.ClosedDate.Value.ToString("dd/MM/yyyy")</dd>
                }
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
